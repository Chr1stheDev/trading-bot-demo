# .env.example
# Copy to .env and fill in your values. Never commit .env to git.

# ── Messaging Interface ────────────────────────────────────────────────────
API_ID=your_api_id
API_HASH=your_api_hash
AUTHORIZED_USER_ID=your_telegram_user_id

# ── Exchange Selection ─────────────────────────────────────────────────────
# Options: mock | ibkr | betfair
EXCHANGE=mock

# ── IBKR (Options Trading) ─────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # 7497 = paper trading | 7496 = live
IBKR_CLIENT_ID=1

# ── Betfair (Racing) ───────────────────────────────────────────────────────
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
BETFAIR_APP_KEY=
BETFAIR_CERT_PATH=./certs/betfair.crt
BETFAIR_KEY_PATH=./certs/betfair.key
